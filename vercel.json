{
  "rewrites": [
    { "source": "/api/compliance/companies", "destination": "/api/complianceCompanies" },
    { "source": "/api/notifications/clear-all", "destination": "/api/notifications?resource=notifications&action=clear-all" },
    { "source": "/api/notifications/read-all", "destination": "/api/notifications?resource=notifications&action=mark-all-read" },
    { "source": "/api/email/settings", "destination": "/api/email?resource=email&route=settings" },
    { "source": "/api/email/test", "destination": "/api/email?resource=email&route=test" },
    { "source": "/api/email/send-digest-now", "destination": "/api/email?resource=email&route=send-digest-now" },
    { "source": "/api/email/send-dashboard-now", "destination": "/api/email?resource=email&route=send-dashboard-now" },
    { "source": "/api/push/vapid-public-key", "destination": "/api/push/handler?route=vapid-public-key" },
    { "source": "/api/push/subscribe", "destination": "/api/push/handler?route=subscribe" },
    { "source": "/api/push/unsubscribe", "destination": "/api/push/handler?route=unsubscribe" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/reminders?window=morning", "schedule": "30 3 * * *" },
    { "path": "/api/reminders?window=evening", "schedule": "0 12 * * *" }
  ]
}