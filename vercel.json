{
  "rewrites": [
    { "source": "/api/attendance", "destination": "/api/[resource]?resource=attendance" },
    { "source": "/api/categories", "destination": "/api/[resource]?resource=categories" },
    { "source": "/api/compliance/companies", "destination": "/api/[resource]?resource=complianceCompanies" },
    { "source": "/api/notifications", "destination": "/api/[resource]?resource=notifications" },
    { "source": "/api/email/settings", "destination": "/api/[resource]?resource=email&route=settings" },
    { "source": "/api/email/test", "destination": "/api/[resource]?resource=email&route=test" },
    { "source": "/api/email/send-digest-now", "destination": "/api/[resource]?resource=email&route=send-digest-now" },
    { "source": "/api/email/send-dashboard-now", "destination": "/api/[resource]?resource=email&route=send-dashboard-now" },
    { "source": "/api/push/vapid-public-key", "destination": "/api/push/handler?route=vapid-public-key" },
    { "source": "/api/push/subscribe", "destination": "/api/push/handler?route=subscribe" },
    { "source": "/api/push/unsubscribe", "destination": "/api/push/handler?route=unsubscribe" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}