{
  "rewrites": [
    { "source": "/api/attendance", "destination": "/api/extra?resource=attendance" },
    { "source": "/api/categories", "destination": "/api/extra?resource=categories" },
    { "source": "/api/compliance/companies", "destination": "/api/extra?resource=complianceCompanies" },
    { "source": "/api/notifications", "destination": "/api/extra?resource=notifications" },
    { "source": "/api/email/settings", "destination": "/api/extra?resource=email&route=settings" },
    { "source": "/api/email/test", "destination": "/api/extra?resource=email&route=test" },
    { "source": "/api/email/send-digest-now", "destination": "/api/extra?resource=email&route=send-digest-now" },
    { "source": "/api/email/send-dashboard-now", "destination": "/api/extra?resource=email&route=send-dashboard-now" },
    { "source": "/api/push/vapid-public-key", "destination": "/api/push/handler?route=vapid-public-key" },
    { "source": "/api/push/subscribe", "destination": "/api/push/handler?route=subscribe" },
